<?xml version="1.0" encoding="utf-8"?>
<!--
  Pin the package source for this repo to the public nuget.org feed only.

  This makes restore reproducible for anyone (and for CI on ubuntu-latest),
  and prevents a developer's machine-level private feed from being consulted
  for this public portfolio repo. Nothing here is secret; there is no feed
  credential and no private source.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
